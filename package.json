{
  "name": "infoenergia",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@mui/styles": "^6.5.0",
    "@mui/x-date-pickers": "^7.0.0",
    "@somenergia/somenergia-ui": "^1.0.0",
    "axios": "^1.13.2",
    "dayjs": "^1.11.0",
    "i18next": "^23.11.2",
    "react": "^18.3.1",
    "react-csv": "^2.2.2",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.0.0",
    "react-router": "^6.30.2",
    "react-router-dom": "^6.30.2",
    "recharts": "^2.1.9",
    "styled-components": "^6.3.9",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "4.0.15",
    "vite-plugin-eslint2": "^5.1.0",
    "@somenergia/frontend-config": "github:Som-Energia/frontend-config#v1.0.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "mutationobserver-shim": "^0.3.7",
    "prettier": "^3.8.3",
    "resize-observer-polyfill": "^1.5.1",
    "vitest": "^4.0.15"
  },
  "scripts": {
    "start": "export VITE_APP_VERSION=$(git rev-parse HEAD) && vite",
    "build": "export VITE_APP_VERSION=$(git rev-parse HEAD) && npm run lint:todos && vite build",
    "test": "TZ=Europe/Madrid vitest",
    "test:coverage": "TZ=Europe/Madrid vitest run --coverage",
    "build:ov": "npm run build  -- --mode=ov",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "lint:todos": "./scripts/todos.sh ./src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "jest": {
    "moduleNameMapper": {
      "^axios$": "axios/dist/node/axios.cjs"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
